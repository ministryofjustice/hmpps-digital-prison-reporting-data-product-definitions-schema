                "formula": "",
                "visible": "true",
                "sortable": true,
                "defaultsort": true
              },
              {
                "name": "$ref:COL2",
                "display": "Col 2 display name",
                "formula": "",
                "visible": "true",
                "sortable": false,
                "defaultsort": false
              }
            ]
          }
        }
