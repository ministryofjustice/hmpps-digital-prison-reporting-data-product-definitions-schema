          ],
          "schema": {
            "field": [
              {
                "index": 0,
                "name": "field_1",
                "type": "string",
                "display": "Field 1",
                "legacyId": "asd.123",
                "legacySqlClass": "column"
              },
              {
                "index": 0,
                "name": "field_2",
                "type": "string",
                "display": "Field 2",
                "legacyId": "asd.45",
                "legacySqlClass": "column"
              },
              {
                "index": 0,
                "name": "field_3",
                "type": "string",
