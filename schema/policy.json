{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/ministryofjustice/hmpps-digital-prison-reporting-data-product-definitions-schema/483172c2c31b8cf051e428aa43db927d2c73b370/schema/policy.json",
  "title": "Data Product Definition Schema",
  "type": "object",
  "required": ["id", "type", "rule", "metadata"],
  "properties": {
    "metadata": {
      "$ref": "#/definitions/metadata"
    },
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "type": {
      "enum": [
        "access",
        "row-level",
        "column-level",
        "masking",
        "privacy",
        "geofencing",
        "timefencing",
        "propagation",
        "retention"
      ]
    },
    "action": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rule": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/policy-rule"
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "metadata": {
      "type": "object",
      "required": ["version"],
      "properties": {
        "author": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "tags": {
          "$ref": "#/definitions/tags"
        }
      },
      "additionalProperties": false
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },

    "policy-rule": {
      "type": "object",
      "required": ["effect", "condition"],
      "properties": {
        "effect": {
          "enum": ["permit", "deny"],
          "default": "deny"
        },
        "condition": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/policy-condition"
          }
        }
      },
      "additionalProperties": false
    },
    "policy-condition": {
      "anyOf": [
        {
          "$ref": "#/definitions/policy-condition-match"
        },
        {
          "$ref": "#/definitions/policy-condition-nomatch"
        },
        {
          "$ref": "#/definitions/policy-condition-like"
        },
        {
          "$ref": "#/definitions/policy-condition-between"
        }
      ]
    },
    "policy-condition-match": {
      "type": "object",
      "properties": {
        "match": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "policy-condition-nomatch": {
      "type": "object",
      "properties": {
        "notequals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "policy-condition-like": {
      "type": "object",
      "properties": {
        "like": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "policy-condition-between": {
      "type": "object",
      "properties": {
        "between": {
          "type": "object",
          "required": ["value", "start", "end"],
          "properties": {
            "value": {
              "type": "string"
            },
            "start": {
              "type": "string"
            },
            "end": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
