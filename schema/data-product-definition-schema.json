{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "datahub://dpd/base",
  "title": "Data Product Definition Schema",
  "type": "object",
  "required": ["id", "name", "metadata", "inputPorts", "outputPorts", "policy"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "scheduled": {
      "type": "boolean"
    },
    "metadata": {
      "$ref": "#/definitions/metadata"
    },
    "inputPorts": {
      "type": "array",
      "items": {
        "$ref": "/inputPorts"
      }
    },
    "outputPorts": {
      "type": "array",
      "items": {
        "$ref": "/outputPorts"
      }
    },
    "policy": {
      "type": "array",
      "items": {
        "$ref": "/policy"
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "metadata": {
      "type": "object",
      "required": ["version"],
      "properties": {
        "author": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "tags": {
          "$ref": "#/definitions/tags"
        }
      },
      "additionalProperties": false
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
