{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/ministryofjustice/hmpps-digital-prison-reporting-data-product-definitions-schema/6f83dd4d8bb93998492372473edc4b2fc5f13d73/schema/data-product-definition-schema.json",
  "title": "Data Product Definition Schema",
  "type": "object",
  "required": ["id", "name", "metadata", "inputPorts", "outputPorts", "policy"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "scheduled": {
      "type": "boolean"
    },
    "metadata": {
      "$ref": "#/definitions/metadata"
    },
    "inputPorts": {
      "type": "array",
      "items": {
        "$ref": "inputPorts.json#/inputPorts"
      }
    },
    "outputPorts": {
      "type": "array",
      "items": {
        "$ref": "outputPorts.json#/outputPorts"
      }
    },
    "policy": {
      "type": "array",
      "items": {
        "$ref": "policy.json#"
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "metadata": {
      "type": "object",
      "required": ["version"],
      "properties": {
        "author": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "tags": {
          "$ref": "#/definitions/tags"
        }
      },
      "additionalProperties": false
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
